APP_ENV=development
LOG_LEVEL=INFO
CONFIG_DIR=config
DATA_DIR=data
REPORTS_DIR=reports
LOGS_DIR=logs
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3

# CoinGecko currently requires a Demo or Pro API key for this endpoint.
# Leave unset when using Yahoo only. Never commit the real key.
# COINGECKO_API_KEY=
# COINGECKO_API_BASE_URL=https://api.coingecko.com/api/v3

# No Robinhood credentials are required or permitted in Phase 2.
