# Python bytecode, packages, and tool caches
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment files and secrets; keep only the safe template
.env
.env.*
!.env.example
secrets/
credentials/
private_keys/
api_keys/
tokens/
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*robinhood*private*key*
*robinhood*api*key*
*robinhood*secret*
*api*key*
*api*secret*
*access*token*
*refresh*token*

# Local databases and runtime state
*.db
*.db-journal
*.sqlite
*.sqlite3
*.sqlite-journal
*.duckdb
*.pid
*.pid.lock

# Downloaded/generated data; retain folder placeholders
# Raw source responses and normalized datasets are reproducible and stay local.
data/raw/*
data/validated/*
data/features/*
data/cache/*
data/tmp/*
!data/raw/.gitkeep
!data/validated/.gitkeep
!data/features/.gitkeep
!data/cache/.gitkeep
!data/tmp/.gitkeep

# Logs and generated reports
logs/*
reports/*
output/*
outputs/*
artifacts/*
runs/*
models/*
checkpoints/*
!logs/.gitkeep
!reports/.gitkeep
*.log
*.out

# Notebooks
.ipynb_checkpoints/

# Editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.code-workspace

# OS and temporary files
.DS_Store
Thumbs.db
Desktop.ini
*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo
*~
